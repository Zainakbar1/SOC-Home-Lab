###############################################################################
# SOC HOME LAB - .gitignore
###############################################################################

###############################################################################
# Operating System
###############################################################################

Thumbs.db
Desktop.ini
.DS_Store
$RECYCLE.BIN/

###############################################################################
# Visual Studio Code
###############################################################################

.vscode/
.history/

###############################################################################
# Python
###############################################################################

__pycache__/
*.py[cod]
*.pyo

###############################################################################
# Logs & Temporary Files
###############################################################################

*.log
*.tmp
*.temp
*.bak
*.old
*.orig

###############################################################################
# VMware Virtual Machines
###############################################################################

# Ignore entire VM storage
02-VMs/**

# Keep documentation
!02-VMs/
!02-VMs/README.md
!02-VMs/**/*.md

# VMware virtual disks
*.vmdk

# VMware snapshots
*.vmsn
*.vmsd
*.vmss

# VMware memory
*.vmem

# VMware configuration
*.vmx
*.vmxf
*.nvram

# VMware locks
*.lck
*.lck/

# VMware metadata
*.scoreboard

# VMware logs
vmware*.log

###############################################################################
# ISO Images
###############################################################################

01-ISO/**

# Keep documentation
!01-ISO/
!01-ISO/README.md
!01-ISO/DownloadLinks.md
!01-ISO/Checksums.md

# Ignore ISO files
*.iso

###############################################################################
# Splunk
###############################################################################

# Installers
*.deb
*.msi
*.rpm

# Runtime
03-Splunk/Runtime/
03-Splunk/Logs/
03-Splunk/var/

# Authentication
03-Splunk/etc/auth/

###############################################################################
# Sysmon
###############################################################################

# Ignore downloaded archive
04-Sysmon/*.zip

# Keep configuration
!04-Sysmon/**/*.xml
!04-Sysmon/**/*.md

###############################################################################
# Packet Captures
###############################################################################

# Ignore large captures
08-PCAP/*.pcap
08-PCAP/*.pcapng

# Keep documentation
!08-PCAP/README.md

# Allow sample captures
!08-PCAP/sample-*.pcap
!08-PCAP/sample-*.pcapng

###############################################################################
# Archives
###############################################################################

*.zip
*.7z
*.rar

###############################################################################
# Crash Dumps
###############################################################################

*.dmp
*.core
MEMORY.DMP

###############################################################################
# Reports
###############################################################################

FolderReport.csv

###############################################################################
# Files that should ALWAYS be tracked
###############################################################################

!*.md
!*.txt
!*.xml
!*.spl
!*.csv
!*.xlsx
!*.json
!*.yaml
!*.yml
!*.drawio
!*.png
!*.jpg
!*.jpeg
!*.svg
!*.pdf
!*.ps1
!*.sh
!*.py